# Neon Postgres (pooled + direct)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# OpenAI (akıllı alet danışmanı / içerik üretimi)
OPENAI_API_KEY="sk-..."

# Admin paneli (x9k4-sys) giriş şifresi
ADMIN_PASSWORD="change-me"

# Mapbox public token (harita tasarımcısı aracı) — pk. ile başlar
NEXT_PUBLIC_MAPBOX_TOKEN="pk...."

# Usta başvurusu / B2B teklif bildirimlerinin gönderileceği admin e-postası (opsiyonel).
# Şu an sadece sunucu loguna yazılır (notify.ts stub); gerçek e-posta sağlayıcısı bağlanınca kullanılır.
ADMIN_NOTIFY_EMAIL="admin@hirdavatpro.com"

# Icecat Open Catalog — resmî ürün görseli + teknik özellik çekimi (ÜCRETSİZ).
# icecat.biz'den ücretsiz hesap aç ve kullanıcı adını buraya yaz.
# Tanımlı değilse görsel/spec çekme tool'u dürüst "hesap aç" uyarısı verir, çökmez.
ICECAT_USERNAME=""

# Affiliate-feed görsel/fiyat fallback adaptörü (opsiyonel, STUB).
# Partner ürün feed uç noktası; tanımlı değilse "bağlı değil" döner (scraping yok).
AFFILIATE_FEED_URL=""
AFFILIATE_FEED_KEY=""
