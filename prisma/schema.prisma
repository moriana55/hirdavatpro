generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        String   @id @default(cuid())
  brand     String
  model     String
  category  String
  specs     Json
  priceRange String? @map("price_range")
  imageUrl  String?  @map("image_url")
  sourceUrl String?  @map("source_url")
  createdAt DateTime @default(now()) @map("created_at")

  comparisonsA Comparison[] @relation("ProductA")
  comparisonsB Comparison[] @relation("ProductB")

  @@unique([brand, model])
  @@index([category])
  @@map("products")
}

model Comparison {
  id        String   @id @default(cuid())
  slug      String   @unique
  productA  String   @map("product_a_id")
  productB  String   @map("product_b_id")
  content   String   @default("")
  verdict   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  productARef Product @relation("ProductA", fields: [productA], references: [id])
  productBRef Product @relation("ProductB", fields: [productB], references: [id])

  @@index([productA])
  @@index([productB])
  @@map("comparisons")
}

// ── B2B teklif talepleri (Feature 5) ──
model B2BQuote {
  id          String   @id @default(cuid())
  companyName String   @map("company_name")
  contactName String   @map("contact_name")
  email       String
  phone       String
  taxNumber   String?  @map("tax_number") // vergi no — cari hesap stub
  items       Json     // [{ query, brand?, model?, productId?, qty }]
  note        String   @default("")
  status      String   @default("new") // new | quoted | won | lost
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("b2b_quotes")
}

// ── Kayıtlı projeler (Feature 6) ──
// Anonim sahip anahtarı (localStorage'da üretilen ownerKey) ile basit eşleştirme.
// Gerçek kullanıcı hesabı yok; ownerKey istemcide saklanır.
model Project {
  id        String   @id @default(cuid())
  ownerKey  String   @map("owner_key") // anon cihaz/kullanıcı anahtarı
  name      String
  desc      String   @default("") // orijinal iş tarifi
  items     Json     // [{ category, categoryLabel, rol, neden, productId?, brand?, model?, priceRange? }]
  notes     String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerKey])
  @@map("projects")
}

// ── Affiliate "nereden alınır" tıklama takibi (Feature: affiliate click tracking) ──
// Kullanıcı dışa yönlendiren bir mağaza linkine tıkladığında kaydedilir.
// PII saklanmaz; yalnızca hangi ürün/mağaza/hedef ve isteğe bağlı referrer host'u.
model AffiliateClick {
  id        String   @id @default(cuid())
  productId String?  @map("product_id") // katalog ürün id'si (varsa)
  slug      String?  // ürün slug'ı (varsa)
  retailer  String   // Hepsiburada | Trendyol | Koçtaş | Amazon TR | Yetkili Bayi ...
  targetUrl String   @map("target_url") // yönlendirilen gerçek mağaza URL'i
  referrer  String?  // istek referrer host'u (PII yok)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([retailer])
  @@index([productId])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

// ── Lead yakalama (Feature: comparison email capture / lead-gen) ──
// Karşılaştırma paylaş/kaydet aksiyonunda OPSİYONEL e-posta. KVKK uyumlu açık rıza.
model Lead {
  id        String   @id @default(cuid())
  email     String
  source    String   @default("comparison") // hangi akıştan geldi
  context   String   @default("") // ör. karşılaştırılan ürünler / slug
  consent   Boolean  @default(false) // açık rıza işaretlendi mi
  createdAt DateTime @default(now()) @map("created_at")

  @@index([source])
  @@index([createdAt])
  @@map("leads")
}

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String   @default("")
  content    String   @default("")
  category   String   @default("")
  coverImage String?  @map("cover_image")
  readTime   String   @default("5 dk")
  published  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([published])
  @@map("blog_posts")
}
